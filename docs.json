{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Metrito",
  "colors": {
    "primary": "#1e55eb",
    "light": "#4d7ef5",
    "dark": "#1240c4"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guias",
        "groups": [
          {
            "group": "Primeiros Passos",
            "pages": ["index", "quickstart"]
          },
          {
            "group": "Rastreamento",
            "pages": [
              "tracking/overview",
              "tracking/web-setup",
              "tracking/utm-configuration",
              "tracking/whatsapp",
              "tracking/events-api",
              "tracking/testing"
            ]
          }
        ]
      },
      {
        "tab": "Referência de API",
        "groups": [
          {
            "group": "Visão Geral",
            "icon": "book",
            "pages": ["api-reference/introduction", "api-reference/authentication", "api-reference/rate-limits"]
          },
          {
            "group": "Plataforma",
            "icon": "grid-2",
            "pages": [
              "openapi/platform.yaml POST /v3/auth/login",
              "openapi/platform.yaml GET /v3/projects",
              "openapi/platform.yaml GET /v3/projects/{project_id}/connections",
              "openapi/data.yaml GET /v3/connections/{connectionId}/sync",
              "openapi/platform.yaml PUT /v3/connections/{connectionId}/objects"
            ]
          },
          {
            "group": "API de Rastreamento",
            "icon": "satellite-dish",
            "pages": [
              {
                "group": "Containers",
                "icon": "box",
                "pages": ["openapi/tracking.yaml GET /v3/tracking/containers/{containerId}"]
              },
              {
                "group": "Gatilhos",
                "icon": "bolt",
                "pages": [
                  "openapi/tracking.yaml GET /v3/tracking/containers/{containerId}/triggers",
                  "openapi/tracking.yaml POST /v3/tracking/containers/{containerId}/triggers",
                  "openapi/tracking.yaml PUT /v3/tracking/containers/{containerId}/triggers/{triggerId}",
                  "openapi/tracking.yaml DELETE /v3/tracking/containers/{containerId}/triggers/{triggerId}"
                ]
              },
              {
                "group": "Eventos",
                "icon": "arrow-right-from-bracket",
                "pages": ["openapi/tracking.yaml POST /v3/tracking/events"]
              },
              {
                "group": "Pedidos",
                "icon": "cart-shopping",
                "pages": ["openapi/tracking.yaml POST /v2/tracking/generic"]
              },
              {
                "group": "Mensagens",
                "icon": "message-lines",
                "pages": ["openapi/tracking.yaml POST /v3/tracking/messages/decode"]
              }
            ]
          },
          {
            "group": "API de Dados",
            "icon": "chart-mixed",
            "pages": ["openapi/data.yaml GET /v3/fields", "openapi/data.yaml POST /v3/query"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Site Oficial",
          "href": "https://metrito.com",
          "icon": "globe"
        },
        {
          "anchor": "Plataforma",
          "href": "https://app.metrito.com",
          "icon": "gauge"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Acessar plataforma",
      "href": "https://app.metrito.com"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "cursor"]
  },
  "footer": {
    "socials": {
      "instagram": "https://instagram.com/metrito.com.br",
      "linkedin": "https://linkedin.com/company/metrito"
    }
  }
}
