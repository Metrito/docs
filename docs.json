{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Metrito",
  "colors": {
    "primary": "#1e55eb",
    "light": "#4d7ef5",
    "dark": "#1240c4"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guias",
        "groups": [
          {
            "group": "Primeiros Passos",
            "pages": ["index", "quickstart"]
          },
          {
            "group": "Rastreamento",
            "pages": [
              "tracking/overview",
              "tracking/web-setup",
              "tracking/utm-configuration",
              "tracking/whatsapp",
              "tracking/events-api",
              "tracking/testing"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Documentação da API",
            "pages": ["api-reference/introduction"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Site Oficial",
          "href": "https://metrito.com",
          "icon": "globe"
        },
        {
          "anchor": "Plataforma",
          "href": "https://app.metrito.com",
          "icon": "gauge"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Acessar plataforma",
      "href": "https://app.metrito.com"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "cursor"]
  },
  "footer": {
    "socials": {
      "instagram": "https://instagram.com/metrito.io",
      "linkedin": "https://linkedin.com/company/metrito"
    }
  }
}
