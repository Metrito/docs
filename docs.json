{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Metrito",
  "colors": {
    "primary": "#2f38f0",
    "light": "#6366f1",
    "dark": "#1e2ad0"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["index", "quickstart"]
          },
          {
            "group": "Tracking",
            "pages": [
              "tracking/overview",
              "tracking/web-setup",
              "tracking/utm-configuration",
              "tracking/whatsapp",
              "tracking/events-api",
              "tracking/testing"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "API Documentation",
            "pages": ["api-reference/introduction"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "App",
          "href": "https://app.metrito.com",
          "icon": "gauge"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.metrito.com"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "cursor"]
  },
  "footer": {
    "socials": {
      "instagram": "https://instagram.com/metrito.io",
      "linkedin": "https://linkedin.com/company/metrito"
    }
  }
}
